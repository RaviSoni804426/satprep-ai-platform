# ==============================================================================
# SATPrep AI - Environment Variables Configuration Template
# Copy this file to '.env' and modify settings for your target environment.
# ==============================================================================

# Core Environment Mode (development / production)
ENV=development

# Database Connection URL (PostgreSQL)
DATABASE_URL=postgresql://user:pass@localhost:5432/satprep

# Redis Cache and OTP TTL Connection URL
REDIS_URL=redis://localhost:6379/0

# Security: JWT Signing Secret Key (IMPORTANT: Change this in production!)
JWT_SECRET_KEY=supersecretjwtkeyforhashingandsigningsatprep
JWT_ALGORITHM=HS256

# Token Lifetime Configurations
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Development Helper: Bypass email sending & accept '123456' as OTP (True / False)
# Set to 'False' in production to enforce real Redis TTL OTP verification.
OTP_BYPASS=True

# CORS Scoping: Allowed Origins (JSON array of strings)
ALLOWED_ORIGINS=["*"]

# Optional S3 File Storage Settings (defaults to local filesystem simulation if empty)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=satprep-ai-bucket
